// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int    @id @default(autoincrement())
  username     String @unique
  password     String
  rootFolderId Int
  rootFolder   Folder @relation(fields: [rootFolderId], references: [id])
  // files    File[]
}

model Folder {
  id             Int      @id @default(autoincrement())
  name           String
  parentFolderId Int?
  parentFolder   Folder?  @relation("Subfolder", fields: [parentFolderId], references: [id])
  subFolders     Folder[] @relation("Subfolder")
  files          File[]
  users          User[]
}

model File {
  id       Int    @id @default(autoincrement())
  folderId Int
  folder   Folder @relation(fields: [folderId], references: [id])
  name     String
  path     String
  size     Int
}

model Session {
  id        String   @id
  sid       String   @unique
  data      String
  expiresAt DateTime
}
